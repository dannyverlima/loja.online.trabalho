@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #0057B7 0%, #003d80 50%, #FFD700 100%);
        height: 350px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin: -1rem -12px 2rem -12px;
        position: relative;
        overflow: hidden;
    }
    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('https://images.unsplash.com/photo-1504148455328-c376907d081c?w=1920') center/cover;
        opacity: 0.2;
    }
    .hero-content {
        text-align: center;
        padding: 2rem;
        position: relative;
        z-index: 1;
    }
    .hero-title {
        font-size: 3rem;
        font-weight: bold;
        letter-spacing: 4px;
        text-transform: uppercase;
        text-shadow: 3px 3px 6px rgba(0,0,0,0.4);
    }
    .hero-subtitle {
        font-size: 1.5rem;
        color: #FFD700;
        font-weight: bold;
        margin-top: 10px;
    }
    .hero-flags {
        font-size: 3rem;
        margin-top: 15px;
    }
    .btn-category {
        padding: 12px 35px;
        margin: 5px;
        border: 2px solid #FFD700;
        background: transparent;
        color: #FFD700;
        text-transform: uppercase;
        font-weight: bold;
        transition: all 0.3s;
        border-radius: 5px;
    }
    .btn-category:hover {
        background: #FFD700;
        color: #0057B7;
    }
    .btn-category.active {
        background: #FFD700;
        color: #0057B7;
    }
    .section-title {
        text-align: center;
        margin: 3rem 0 1rem;
    }
    .section-title h2 {
        font-weight: bold;
        color: #0057B7;
        font-style: italic;
    }
    .section-title p {
        color: #666;
    }
    .product-card {
        background: linear-gradient(145deg, #f8f8f8 0%, #e8e8e8 100%);
        padding: 20px;
        margin-bottom: 30px;
        text-align: center;
        transition: transform 0.3s, box-shadow 0.3s;
        border-radius: 10px;
        border: 2px solid transparent;
    }
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,87,183,0.2);
        border-color: #FFD700;
    }
    .product-card img {
        max-width: 100%;
        height: 180px;
        object-fit: contain;
        margin-bottom: 15px;
    }
    .product-name {
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.85rem;
        margin-bottom: 5px;
        color: #0057B7;
    }
    .product-price {
        color: #333;
        font-weight: bold;
        font-size: 1.2rem;
    }
    .product-brand {
        color: #FFD700;
        background: #0057B7;
        padding: 2px 10px;
        border-radius: 3px;
        font-size: 0.7rem;
        display: inline-block;
        margin-bottom: 10px;
    }
    .product-store {
        color: #888;
        font-size: 0.8rem;
        margin-top: 5px;
    }
    .free-shipping {
        color: #28a745;
        font-size: 0.75rem;
    }
</style>

<!-- Banner Hero -->
<div class="hero-section">
    <div class="hero-content">
        <div class="hero-title">UCRENRUSS MaKota</div>
        <div class="hero-subtitle">Ferramentas Profissionais de Alta Qualidade</div>
        <div class="hero-flags">🇺🇦 🤝 🇷🇺</div>
        <div class="mt-4">
            <button class="btn btn-category active">BERBEQUINS</button>
            <button class="btn btn-category">SERRAS</button>
            <button class="btn btn-category">KITS</button>
        </div>
    </div>
</div>

<!-- Secção Novidades -->
<div class="section-title">
    <h2>NOVIDADES EM FERRAMENTAS!</h2>
    <p>Descubra as melhores ferramentas profissionais para os seus projetos.</p>
</div>

